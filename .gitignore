# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
venv/
ENV/
env/

# UV package manager
.python-version
uv.lock

# Testing
.pytest_cache/
.coverage
htmlcov/
*.cover

# IDE
.vscode/
.idea/
*.swp
*.two
*~
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db
.directory

# Game-specific
*.log
debug_output/

# Copyrighted Capcom assets (all sprites, backgrounds, and extracted frames).
# The canonical asset tree lives under assets/ (see assets/README.md); character
# animations were consolidated there from tools/sprite_extraction/.
# Ignore every asset file but keep the README tracked so the layout + ownership
# note live in the repo (a bare `assets/` would make the README un-trackable).
assets/*
!assets/README.md
# Legacy extraction output dirs (kept ignored in case the tools regenerate them)
tools/sprite_extraction/akuma_gifs/
tools/sprite_extraction/character_portraits/
public/*.gif

# Local config (if we add user-specific settings later)
config.local.json
*.local

# Keep assets but ignore temporary files
*.tmp
*.bak

# Writing and documentation drafts
writing/

# Debug snapshot dumps (F12 in-game)
debug_snapshots/

# Audit/catalog filmstrips embed copyrighted sprite art — keep the markdown
# indexes tracked, but not the rendered PNG/GIF contact sheets.
docs/animation_audit/
docs/asset_catalog/**/*.png
docs/asset_catalog/**/*.gif
